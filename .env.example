# Uncomment to enable Prefect API basic auth
#PREFECT_SERVER_API_AUTH_STRING=admin:admin
#PREFECT_API_AUTH_STRING=admin:admin

PREFECT_SERVER_ANALYTICS_ENABLED=false
PREFECT_SERVER_UI_SHOW_PROMOTIONAL_CONTENT=false

POSTGRES_PASSWORD=prefect
RUSTFS_ACCESS_KEY=admin
RUSTFS_SECRET_KEY=admin

# DHIS2 credentials (required by all DHIS2 import flows)
#DHIS2_BASE_URL=https://play.im.dhis2.org/dev
#DHIS2_USERNAME=admin
#DHIS2_PASSWORD=district

# CDS API key for ERA5 climate data downloads (https://cds.climate.copernicus.eu/profile)
#CDSAPI_KEY=<your-cds-api-key>

# Slack incoming webhook URL (used by notification flows)
#SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00/B00/xxxx
